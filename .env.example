# Copy this file to .env and fill in the values.
# .env is git-ignored and must NEVER be committed.

# Required for CLI usage only (web UI accepts cookies via the form)
X_COOKIES=auth_token=PASTE_HERE; ct0=PASTE_HERE

# Optional — Flask secret key. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# If not set, a random key is generated on each restart (fine for stateless use).
SECRET_KEY=

# Port — defaults to 7070 locally; set automatically by Render/Railway
# PORT=7070
